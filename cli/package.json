{
  "name": "tacitus-cli",
  "version": "0.1.0",
  "description": "Tacitus CLI — silent disposable email from your terminal",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "tac": "./bin/run.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "convex": "^1.0.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0"
  },
  "oclif": {
    "bin": "tac",
    "dirname": "tacitus",
    "commands": "./src/commands",
    "plugins": []
  }
}
